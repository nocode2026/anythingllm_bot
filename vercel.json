{
  "version": 2,
  "builds": [
    {
      "src": "chatbot/chat-widget/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "chatbot/chat-widget/dist/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_WIDGET_VERSION": "@vite_widget_version"
  },
  "buildCommand": "cd chatbot && pnpm install && pnpm --filter @sum/chat-widget build",
  "outputDirectory": "chatbot/chat-widget/dist"
}
